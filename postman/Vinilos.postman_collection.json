{
  "info": {
    "_postman_id": "6b2c7f3b-2d7a-4c33-9d2b-7f1a7df0a3a1",
    "name": "Vinilos API",
    "description": "Colección para validar los endpoints de albums, musicians y bands del backend de Vinilos.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Albums",
      "item": [
        {
          "name": "GET Albums",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/albums",
            "description": "Obtiene el catálogo de álbumes."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each album has the expected fields', function () {",
                  "  const body = pm.response.json();",
                    "  pm.expect(body).to.have.length(4);",
                    "  const names = body.map(function (album) { return album.name; });",
                    "  pm.expect(names).to.include('Buscando América');",
                    "  pm.expect(names).to.include('Poeta del pueblo');",
                    "  pm.expect(names).to.include('A Night at the Opera');",
                    "  pm.expect(names).to.include('A Day at the Races');",
                    "  body.forEach(function (album) {",
                  "    pm.expect(album).to.have.property('id');",
                  "    pm.expect(album).to.have.property('name');",
                  "    pm.expect(album).to.have.property('cover');",
                  "    pm.expect(album).to.have.property('releaseDate');",
                  "    pm.expect(album).to.have.property('description');",
                  "    pm.expect(album).to.have.property('genre');",
                  "    pm.expect(album).to.have.property('recordLabel');",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Musicians",
      "item": [
        {
          "name": "GET Musicians",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/musicians",
            "description": "Obtiene el catálogo de músicos."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is an array', function () {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Each musician has the expected fields', function () {",
                  "  const body = pm.response.json();",
                    "  pm.expect(body).to.have.length(1);",
                  "  body.forEach(function (artist) {",
                  "    pm.expect(artist).to.have.property('id');",
                  "    pm.expect(artist).to.have.property('name');",
                  "    pm.expect(artist).to.have.property('image');",
                  "    pm.expect(artist).to.have.property('description');",
                    "    pm.expect(artist.name).to.equal('Rubén Blades Bellido de Luna');",
                    "    pm.expect(artist.id).to.equal(100);",
                  "    pm.expect(artist).to.satisfy(function (item) {",
                  "      return Object.prototype.hasOwnProperty.call(item, 'birthDate') || Object.prototype.hasOwnProperty.call(item, 'creationDate');",
                  "    });",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
