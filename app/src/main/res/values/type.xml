<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Títulos principales (ej. nombre de álbum en lista) -->
    <style name="TextAppearance.Vinilos.TitleLarge" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Subtítulos (ej. género, fecha) -->
    <style name="TextAppearance.Vinilos.TitleMedium" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">normal</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Cuerpo principal -->
    <style name="TextAppearance.Vinilos.BodyLarge" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Cuerpo secundario (ej. descripción corta) -->
    <style name="TextAppearance.Vinilos.BodyMedium" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

    <!-- Etiquetas pequeñas -->
    <style name="TextAppearance.Vinilos.Label" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/black</item>
    </style>

</resources>
